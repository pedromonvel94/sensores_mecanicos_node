# --- Dependencias de Node ---
node_modules/
**/node_modules/

# --- Compilación y Salidas ---
dist/
**/dist/
build/
bin/
obj/

# --- Configuración y Secretos (Seguridad) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.vault
# No ignorar .env.example
!.env.example

# Certificados de Base de Datos
**/ca.pem
# No ignorar ca.pem.example
!**/ca.pem.example

# --- Logs y Temporales ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
.eslintcache
.DS_Store
Thumbs.db

# --- Editores e IDEs ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

