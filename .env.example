# --- CONFIGURACIÓN DEL SERVIDOR BACKEND ---
PORT=3000

# --- CONFIGURACIÓN DE LA BASE DE DATOS MYSQL (AIVEN) ---
DB_HOST=tu_host_aiven_mysql.k.aivencloud.com
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
